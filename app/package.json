{
  "name": "canvas-inbox-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "test:electron": "node --test electron/windowChrome.test.cjs electron/shortcutDisplay.test.cjs electron/capturePipeline.test.cjs electron/sourceCardAnalysis.test.cjs electron/sourceInbox.test.cjs electron/sourceDelete.test.cjs electron/taskDelete.test.cjs src/settingsPanelLayout.test.cjs && node --experimental-transform-types --test src/lib/captureFocus.test.ts src/lib/recentlyDeletedSourceSuppression.test.ts",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "25.4.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "electron": "41.0.0",
    "electron-builder": "26.0.12",
    "typescript": "5.9.3",
    "vite": "8.0.0",
    "wait-on": "9.0.4"
  },
  "build": {
    "appId": "com.canvasinbox.desktop",
    "productName": "Canvas Inbox",
    "directories": {
      "output": "electron-builder",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/app-icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/app-icon.icns",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Canvas Inbox",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  }
}
